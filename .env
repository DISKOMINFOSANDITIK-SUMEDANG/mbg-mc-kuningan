NODE_ENV=development

# -----------------------------------------------------------------------------
# Source repositories used by docker compose
# -----------------------------------------------------------------------------
FRONTEND_SOURCE_DIR=./mbg-frontend-git
BACKEND_SOURCE_DIR=./mbg-backend-git

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_USER=mbg_user
DB_PASSWORD=mbg_password
DB_NAME=mbg_db
DB_PORT=5432
DATABASE_URL=postgresql://mbg_user:mbg_password@postgres:5432/mbg_db

DB_POOL_SIZE=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# -----------------------------------------------------------------------------
# Backend (Express API)
# -----------------------------------------------------------------------------
API_PORT=3001
JWT_SECRET=dev-secret-key-for-development
JWT_EXPIRY=7d

# CORS (comma-separated). Add your server IP/domain here if you access without DNS.
CORS_ORIGIN=http://localhost,http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3002,https://localhost,http://192.168.18.155,http://192.168.18.155:80,http://192.168.18.155:3000

# Rate Limiting (relaxed for development)
RATE_LIMIT_WINDOW_MS=120000
RATE_LIMIT_MAX_REQUESTS=100

CRON_SECRET=

# -----------------------------------------------------------------------------
# Storage / MinIO (Local Object Storage)
# -----------------------------------------------------------------------------
STORAGE_TYPE=s3
UPLOADS_DIR=./uploads
STORAGE_BASE_URL=http://192.168.18.155/storage

S3_ENDPOINT=http://minio:9000
S3_REGION=auto
S3_ACCESS_KEY=mbgadmin
S3_SECRET_KEY=mbgadmin123
S3_BUCKET=mbg-storage
S3_BUCKET_PREFIX=stub/mbg_bucket
S3_PHOTO_BUCKET_PREFIX=stub
S3_PUBLIC_URL=http://192.168.18.155/storage
S3_FORCE_PATH_STYLE=true

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
FRONTEND_PORT=3002
API_URL=http://backend:3001
NEXT_PUBLIC_API_URL=http://192.168.18.155:3001
NEXT_PUBLIC_BASE_URL=http://192.168.18.155
NEXT_PUBLIC_STORAGE_BASE_URL=http://192.168.18.155/storage
NEXT_PUBLIC_STORAGE_BUCKET=mbg-storage

# -----------------------------------------------------------------------------
# MinIO (local object storage, pinned to cpuv1 for older x86_64 CPUs)
# -----------------------------------------------------------------------------
MINIO_IMAGE=minio/minio:RELEASE.2025-06-13T11-33-47Z-cpuv1
MINIO_MC_IMAGE=minio/mc:RELEASE.2025-08-13T08-35-41Z-cpuv1
MINIO_ROOT_USER=mbgadmin
MINIO_ROOT_PASSWORD=mbgadmin123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# Nginx reverse proxy
# -----------------------------------------------------------------------------
NGINX_SSL_ENABLED=false
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# -----------------------------------------------------------------------------
# pgAdmin (profile: dev)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@mbg.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
